<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>AntGold — Stake & Earn | Colonie Solana</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --bg: #0d0812;
    --surface: #160d20;
    --border: #2e1a45;
    --gold: #f0c040;
    --gold2: #ffd97d;
    --gold3: #ffe9a8;
    --mauve: #c084fc;
    --mauve2: #e9d5ff;
    --text: #f5eeff;
    --muted: #7c6a9a;
    --glow-g: 0 0 40px rgba(240,192,64,0.25);
    --glow-m: 0 0 40px rgba(192,132,252,0.2);
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Mono', monospace;
    overflow-x: hidden;
    cursor: none;
  }

  /* custom cursor */
  #cur, #cur2 {
    position: fixed;
    pointer-events: none;
    z-index: 9999;
    border-radius: 50%;
  }
  #cur {
    width: 8px;
    height: 8px;
    background: var(--gold);
    mix-blend-mode: difference;
    transition: transform 0.05s linear;
  }
  #cur2 {
    width: 36px;
    height: 36px;
    border: 1px solid var(--gold);
    opacity: 0.4;
    transition: all 0.1s ease;
  }

  /* background orbs */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 20% 20%, rgba(192,132,252,0.08) 0%, transparent 60%),
                radial-gradient(ellipse 60% 80% at 80% 80%, rgba(240,192,64,0.06) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  /* floating particles */
  .particles {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  .p {
    position: absolute;
    width: 2px;
    height: 2px;
    background: var(--gold);
    border-radius: 50%;
    animation: float linear infinite;
    opacity: 0;
  }
  @keyframes float {
    0% { transform: translateY(100vh) rotate(0deg); opacity: 0; }
    10% { opacity: 0.6; }
    90% { opacity: 0.3; }
    100% { transform: translateY(-20px) rotate(720deg); opacity: 0; }
  }

  /* navigation */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 3rem;
    background: rgba(13,8,18,0.85);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
  }
  .logo {
    font-family: 'Cinzel', serif;
    font-size: 1.3rem;
    font-weight: 900;
    color: var(--gold);
    text-shadow: 0 0 20px rgba(240,192,64,0.5);
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .logo img {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    object-fit: cover;
  }
  nav ul {
    list-style: none;
    display: flex;
    gap: 2rem;
  }
  nav a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  nav a:hover {
    color: var(--gold);
  }
  .nav-btn {
    background: linear-gradient(135deg, var(--gold), var(--gold2));
    color: #0d0812;
    border: none;
    padding: 0.5rem 1.5rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .nav-btn:hover {
    box-shadow: var(--glow-g);
    transform: translateY(-1px);
  }

  /* hero */
  .hero {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 8rem 2rem 4rem;
  }
  .hero-tag {
    font-size: 0.7rem;
    color: var(--mauve);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .hero-tag::before,
  .hero-tag::after {
    content: '';
    flex: 1;
    max-width: 60px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--mauve));
  }
  .hero-tag::after {
    background: linear-gradient(90deg, var(--mauve), transparent);
  }
  .hero-icon {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    object-fit: cover;
    filter: drop-shadow(0 0 30px rgba(240,192,64,0.7));
    animation: antFloat 3s ease-in-out infinite;
    margin-bottom: 1rem;
  }
  @keyframes antFloat {
    0%,100% { transform: translateY(0) rotate(-2deg); }
    50% { transform: translateY(-15px) rotate(2deg); }
  }
  h1 {
    font-family: 'Cinzel', serif;
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }
  h1 .g {
    background: linear-gradient(135deg, var(--gold), var(--gold2), var(--gold3));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .hero-sub {
    font-size: 1rem;
    color: var(--muted);
    max-width: 550px;
    line-height: 1.7;
    margin: 1.5rem auto 2.5rem;
  }
  .hero-btns {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn-gold {
    background: linear-gradient(135deg, var(--gold), var(--gold2));
    color: #0d0812;
    border: none;
    padding: 0.9rem 2.2rem;
    font-family: 'Cinzel', serif;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
    display: inline-block;
  }
  .btn-gold:hover {
    box-shadow: var(--glow-g);
    transform: translateY(-2px);
  }
  .btn-ghost {
    background: transparent;
    color: var(--gold2);
    border: 1px solid var(--border);
    padding: 0.9rem 2.2rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    border-radius: 4px;
    transition: all 0.2s;
    text-decoration: none;
    display: inline-block;
  }
  .btn-ghost:hover {
    border-color: var(--gold);
    color: var(--gold);
  }

  /* stats */
  .stats {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }
  .stat {
    padding: 2rem 1rem;
    text-align: center;
    border-right: 1px solid var(--border);
  }
  .stat:last-child { border-right: none; }
  .stat-v {
    font-family: 'Cinzel', serif;
    font-size: 2rem;
    font-weight: 700;
    background: linear-gradient(135deg, var(--gold), var(--gold2));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    display: block;
    margin-bottom: 0.4rem;
  }
  .stat-l {
    font-size: 0.65rem;
    color: var(--muted);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  section {
    position: relative;
    z-index: 1;
    padding: 6rem 4rem;
  }
  .s-tag {
    font-size: 0.65rem;
    color: var(--gold);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  h2 {
    font-family: 'Cinzel', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 1.5rem;
    background: linear-gradient(135deg, var(--text), var(--mauve2));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* tiers */
  .tiers {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-top: 3rem;
  }
  .tier {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem 1.5rem;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }
  .tier::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--gold), var(--gold2));
    transform: scaleX(0);
    transition: transform 0.3s;
  }
  .tier:hover {
    transform: translateY(-5px);
    border-color: rgba(240,192,64,0.4);
    box-shadow: var(--glow-g);
  }
  .tier:hover::before {
    transform: scaleX(1);
  }
  .tier.best {
    border-color: rgba(240,192,64,0.5);
    background: linear-gradient(135deg, rgba(240,192,64,0.05), var(--surface));
  }
  .tier-badge {
    font-size: 0.6rem;
    background: var(--gold);
    color: #0d0812;
    padding: 0.2rem 0.7rem;
    border-radius: 20px;
    display: inline-block;
    margin-bottom: 1rem;
    letter-spacing: 0.05em;
  }
  .tier-dur {
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
  }
  .tier-mult {
    font-family: 'Cinzel', serif;
    font-size: 3rem;
    font-weight: 900;
    background: linear-gradient(135deg, var(--gold), var(--gold2));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    line-height: 1;
  }
  .tier-earn {
    font-size: 0.85rem;
    color: var(--mauve);
    margin: 0.8rem 0;
    font-weight: 500;
  }
  .tier-desc {
    font-size: 0.72rem;
    color: var(--muted);
    line-height: 1.6;
  }

  /* steps */
  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 4rem;
    counter-reset: step;
  }
  .step {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
    position: relative;
    counter-increment: step;
  }
  .step::before {
    content: counter(step, decimal-leading-zero);
    font-family: 'Cinzel', serif;
    font-size: 4rem;
    font-weight: 900;
    color: rgba(240,192,64,0.1);
    position: absolute;
    top: 1rem;
    right: 1.5rem;
    line-height: 1;
  }
  .step-icon {
    font-size: 2.2rem;
    margin-bottom: 0.8rem;
  }
  .step h3 {
    font-family: 'Cinzel', serif;
    font-size: 1.2rem;
    color: var(--gold);
    margin-bottom: 0.7rem;
  }
  .step p {
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.7;
  }

  /* app & calculator */
  .app-section {
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .app-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    margin-top: 2.5rem;
  }
  .app-card {
    background: rgba(240,192,64,0.04);
    border: 1px solid rgba(240,192,64,0.2);
    border-radius: 20px;
    padding: 2rem;
  }
  .input-group {
    margin-bottom: 1.5rem;
  }
  .input-label {
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.5rem;
  }
  .input-field {
    width: 100%;
    background: rgba(0,0,0,0.4);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.8rem 1rem;
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 0.9rem;
    outline: none;
    transition: border 0.2s;
  }
  .input-field:focus {
    border-color: var(--gold);
  }
  .calc-result {
    background: rgba(240,192,64,0.06);
    border-radius: 14px;
    padding: 1.5rem;
    margin-top: 1.5rem;
  }
  .calc-row {
    display: flex;
    justify-content: space-between;
    padding: 0.6rem 0;
    border-bottom: 1px solid rgba(240,192,64,0.1);
    font-size: 0.8rem;
  }
  .calc-val.big {
    font-family: 'Cinzel', serif;
    font-size: 1.4rem;
    color: var(--gold2);
  }

  /* tokenomics */
  .tknomics {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    margin-top: 3rem;
  }
  .tknomics-list {
    list-style: none;
  }
  .tknomics-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.8rem;
  }
  .tknomics-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* security grid */
  .security-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 3rem;
  }
  .security-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.8rem;
    text-align: center;
  }

  /* faq */
  .faq-item {
    border: 1px solid var(--border);
    border-radius: 12px;
    margin-bottom: 1rem;
  }
  .faq-question {
    width: 100%;
    background: none;
    border: none;
    padding: 1.2rem 1.5rem;
    text-align: left;
    font-family: 'Cinzel', serif;
    font-size: 0.9rem;
    color: var(--text);
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
  }
  .faq-answer {
    display: none;
    padding: 0 1.5rem 1.2rem;
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.7;
  }

  /* roadmap */
  .roadmap-line {
    position: relative;
    margin-top: 2.5rem;
  }
  .roadmap-item {
    display: flex;
    gap: 2rem;
    padding: 1rem 0;
  }

  footer {
    padding: 2.5rem 4rem;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.7rem;
    color: var(--muted);
  }

  @media (max-width: 900px) {
    nav ul { display: none; }
    section { padding: 4rem 1.5rem; }
    .stats { grid-template-columns: repeat(2, 1fr); }
    .tiers, .steps, .security-grid { grid-template-columns: 1fr; }
    .app-grid, .tknomics { grid-template-columns: 1fr; }
    .hero { padding-top: 6rem; }
    footer { padding: 1.5rem; flex-direction: column; text-align: center; }
  }
</style>
</head>
<body>

<div id="cur"></div>
<div id="cur2"></div>
<div class="particles" id="particles"></div>

<nav>
  <div class="logo"><img src="https://i.imgur.com/uEQ9ZAr.png" alt="antgold"> AntGold</div>
  <ul>
    <li><a href="#staking">Staking</a></li>
    <li><a href="#tiers">Paliers</a></li>

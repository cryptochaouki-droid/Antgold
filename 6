</div>

<div class="stats">
  <div class="stat"><span class="stat-v">1B</span><span class="stat-l">Supply $ANTG</span></div>
  <div class="stat"><span class="stat-v">0.001$</span><span class="stat-l">Prix lancement</span></div>
  <div class="stat"><span class="stat-v">90$/mois</span><span class="stat-l">Gain maximum</span></div>
  <div class="stat"><span class="stat-v">x3</span><span class="stat-l">Multiplicateur max</span></div>
</div>

<section id="tiers">
  <div class="s-tag">// Paliers de récompense</div>
  <h2>Plus tu restes,<br>plus tu gagnes.</h2>
  <p style="color:var(--muted); max-width:500px; margin-bottom:2rem;">Système Time-Weighted récompense la fidélité.</p>

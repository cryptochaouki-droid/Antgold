<script>
  // ---- custom cursor ----
  const cursor = document.getElementById('cur');
  const cursor2 = document.getElementById('cur2');
  let mouseX = 0, mouseY = 0;
  let curX = 0, curY = 0;
  document.addEventListener('mousemove', (e) => {
    mouseX = e.clientX;
    mouseY = e.clientY;
    cursor.style.left = mouseX - 4 + 'px';
    cursor.style.top = mouseY - 4 + 'px';
  });
  function animateCursor() {
    curX += (mouseX - curX) * 0.12;
    curY += (mouseY - curY) * 0.12;
    cursor2.style.left = curX - 18 + 'px';
    cursor2.style.top = curY - 18 + 'px';
    requestAnimationFrame(animateCursor);
  }
  animateCursor();

  // ---- floating particles ----
  const partContainer = document.getElementById('particles');
  for (let i = 0; i < 45; i++) {
    let p = document.createElement('div');
    p.classList.add('p');
    p.style.left = Math.random() * 100 + '%';
    p.style.animationDuration = 6 + Math.random() * 15 + 's';
    p.style.animationDelay = Math.random() * 12 + 's';
    p.style.width = p.style.height = 1 + Math.random() * 3 + 'px';
    partContainer.appendChild(p);
  }

  // ---- calculator ----
  const stakeInput = document.getElementById('stakeAmount');
  const durationSelect = document.getElementById('duration');
  const rValSpan = document.getElementById('r-val');
  const rDaySpan = document.getElementById('r-day');
  const rMonthSpan = document.getElementById('r-month');
  const rYearSpan = document.getElementById('r-year');

  function updateCalculator() {
    let usd = parseFloat(stakeInput.value);
    if (isNaN(usd) || usd < 1) usd = 1;
    const mult = parseFloat(durationSelect.value);
    const basePerDay = (usd / 25) * 1; // 25$ = 1$/jour base
    const daily = basePerDay * mult;
    const monthly = daily * 30;
    const yearly = daily * 365;
    const antgAmount = usd / 0.001;
    rValSpan.innerText = `${usd.toFixed(2)}$ (${Math.floor(antgAmount).toLocaleString()} ANTG)`;
    rDaySpan.innerText = `${daily.toFixed(2)}$/jour`;
    rMonthSpan.innerText = `${monthly.toFixed(2)}$/mois`;
    rYearSpan.innerText = `${yearly.toFixed(2)}$/an`;
  }
  stakeInput.addEventListener('input', updateCalculator);
  durationSelect.addEventListener('change', updateCalculator);
  updateCalculator();

  // ---- faq toggle ----
  const faqButtons = document.querySelectorAll('.faq-question');
  faqButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const answer = btn.nextElementSibling;
      const signSpan = btn.querySelector('span');
      if (answer.style.display === 'block') {
        answer.style.display = 'none';
        signSpan.innerText = '+';
      } else {
        answer.style.display = 'block';
        signSpan.innerText = '−';
      }
    });
  });

  // ---- wallet simulation (popup reminder) ----
  function walletConnectAction() {
    alert("🐜 Connexion Phantom simulée.\n\nDans la version finale, le wallet Phantom s'intégrerait via window.solana.\nIci, le design est prêt pour l'intégration mainnet !");
  }
  const walletBtns = document.querySelectorAll('#walletConnectBtn, #ctaWalletBtn');
  walletBtns.forEach(btn => btn.addEventListener('click', walletConnectAction));

  // ---- smooth scroll & animation observer ----
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function(e) {
      e.preventDefault();
      const targetId = this.getAttribute('href').substring(1);
      const target = document.getElementById(targetId);
      if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  const fadeElements = document.querySelectorAll('.tier, .step, .security-card, .tknomics-item');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.style.opacity = '1';
        entry.target.style.transform = 'translateY(0px)';
      }
    });
  }, { threshold: 0.1 });
  fadeElements.forEach(el => {
    el.style.opacity = '0';
    el.style.transform = 'translateY(20px)';
    el.style.transition = 'opacity 0.5s ease, transform 0.4s ease';
    observer.observe(el);
  });

  // ---- final touch : logo bonus display ----
  console.log("AntGold — colonie active");
</script>
